---
// "Copy prompt" CTA — mirrors Cloudflare's docs overview. Copies an LLM-ready
// prompt that primes an assistant with Orchard context + the canonical doc/repo
// URLs, supporting the agent-accessibility pillar. Styled to match Starlight's
// secondary LinkButton so it pairs with the primary "Get started" button.
interface Props {
  /** Override the copied prompt; defaults to a site-wide Orchard primer. */
  prompt?: string;
  label?: string;
}

const {
  label = 'Copy prompt',
  prompt = `I'm working with Orchard, an all-in-one manager for Cashu mints (Chaumian ecash for Bitcoin). Use the official documentation at https://docs.orchard.space as your source of truth, and the source code at https://github.com/cashubtc/orchard. Help me set up, run, and operate my own Cashu mint with Orchard.`,
} = Astro.props;
---

<button type="button" class="copy-prompt" data-copy-prompt data-prompt={prompt} aria-label={`${label} — copies an AI prompt about Orchard to your clipboard`}>
  <svg class="copy-prompt__icon copy-prompt__icon--copy" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="9" y="9" width="11" height="11" rx="2" />
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
  </svg>
  <svg class="copy-prompt__icon copy-prompt__icon--done" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 6 9 17l-5-5" />
  </svg>
  <span data-copy-label>{label}</span>
</button>

<style>
  /* Dashed secondary CTA — the marketing site's "Read the Docs" button: dashed
     cream border (→ full cream on hover), transparent fill, matching the primary
     button's rounded corners and size. */
  .copy-prompt {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 0.75rem;
    border: 1px dashed color-mix(in srgb, var(--sl-color-white) 40%, transparent);
    background: transparent;
    color: var(--sl-color-white);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.1875;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .copy-prompt:hover {
    border-color: var(--sl-color-white);
  }
  .copy-prompt:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }
  .copy-prompt__icon {
    flex: none;
  }
  .copy-prompt__icon--done {
    display: none;
    color: var(--sl-color-accent);
  }
  .copy-prompt.is-copied {
    border-color: var(--sl-color-accent);
  }
  .copy-prompt.is-copied .copy-prompt__icon--copy {
    display: none;
  }
  .copy-prompt.is-copied .copy-prompt__icon--done {
    display: inline;
  }
</style>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-copy-prompt]')) {
    const labelEl = btn.querySelector<HTMLElement>('[data-copy-label]');
    const original = labelEl?.textContent ?? '';
    let timer: ReturnType<typeof setTimeout> | undefined;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.prompt ?? '');
        btn.classList.add('is-copied');
        if (labelEl) labelEl.textContent = 'Copied!';
        clearTimeout(timer);
        timer = setTimeout(() => {
          btn.classList.remove('is-copied');
          if (labelEl) labelEl.textContent = original;
        }, 2000);
      } catch {
        // Clipboard unavailable (e.g. insecure context) — leave the button as is.
      }
    });
  }
</script>
