---
// Override of Starlight's SocialIcons: use Orchard's own Nostr "nostrich" mark
// (matching the marketing site) in place of Starlight's built-in nostr glyph.
// Everything else mirrors the upstream component — it still renders from the
// `social` config and keeps the same markup, so layout is unchanged. Color is
// left to the `.social-icons a` rule in orchard.css.
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const links = config.social || [];
---

{
  links.length > 0 && (
    <>
      {links.map(({ label, href, icon }) => (
        <a href={href} rel="me" class="sl-flex">
          <span class="sr-only">{label}</span>
          {icon === 'nostr' ? (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 112.29 128" width="1em" height="1em" aria-hidden="true">
              <path fill="currentColor" d="M96.82.02s3.03-.43,6.27,2.6c0,0,2.16,1.51,5.41,2.16,3.25.65,3.68,1.3,3.68,1.3,0,0,.43.87-.43.87h-1.97c-.07,0-.09.1-.02.12l1.56.53s.87.22.65.87-3.03.43-3.03.43c0,0-4.76.22-6.06.43s-3.03.87-3.03.87c0,0-1.95,1.08,0,3.25,1.95,2.16,4.11,3.68,4.11,3.68,0,0,6.27,3.89,7.57,9.3,1.3,5.41,1.08,8.44-1.73,14.06-2.81,5.63-9.09,10.17-11.03,11.03-1.95.87-3.25,1.95-3.25,1.95,0,0-.87.43-.87,2.38s.87,8.65-4.11,13.2c-4.98,4.54-12.55,5.41-12.55,5.41,0,0-5.41.65-8.65.43,0,0-1.3,0-1.73.87s-.87,1.95-2.81,2.81c-1.95.87-3.25,3.03-3.25,3.03l-1.3,1.88c-.21.3.08.69.43.58l20.99-6.79s3.68-1.08,5.63.87l5.84,8.87s.87,1.08.22,1.73-2.6-.43-2.6-.43c0,0-2.81-2.38-3.46-3.25s-1.08-.65-1.08-.65c0,0-.65.43-.22,1.3.43.87.22,1.73.22,1.73,0,0-.65.65-1.08.22s-1.51-1.08-1.73-2.38c-.22-1.3-.22-1.51-.22-1.51,0,0,0-1.08-1.51-.87-1.51.22-19.47,5.84-19.47,5.84,0,0-1.73.43-3.25,1.51-1.51,1.08-2.81.87-3.89.22s-1.73-2.6-1.3-4.11c.43-1.51,1.08-4.33,1.95-5.84s1.51-2.16,1.51-2.16c0,0,.65-.87.22-1.3s-1.95.43-1.95.43l-4.54,1.73-10.39,7.79s-.65.22-.87,1.08c-.22.87-1.3,3.68-3.89,4.76-2.6,1.08-3.68,3.03-3.68,3.03l-13.41,18.39s-1.51,3.46-5.41,6.71c0,0-2.81,2.81-3.68,5.41-.87,2.6-1.95,1.3-1.95,1.3,0,0-1.3-1.51-.22-5.41,1.08-3.89,2.38-4.33,2.38-4.33,0,0,.65-.43.43-.87s-1.08,0-1.08,0c0,0-1.3.43-1.51-.22s-.22-1.95.87-2.81,2.16-2.16,5.19-2.6c3.03-.43,8.01-9.52,8.01-9.52l7.14-10.17s.65-.65.87-1.95.87-4.11,3.89-5.19,9.95-7.57,9.95-7.57c0,0,2.38-2.16,2.6-3.03.22-.87.87-1.3-.43-1.51-1.3-.22-9.52-2.16-13.63-4.33-4.11-2.16-4.11-2.38-4.11-2.38,0,0-.87-.65-3.03-.22s-4.33.43-6.27,1.3c-1.95.87-4.76,2.38-4.76,2.38,0,0-1.3,1.3-2.16.87s-.43-3.46-.43-3.46c0,0,.22-1.3.65-2.16.43-.87-.22-1.08-.22-1.08,0,0-.43-.43-2.81,2.16-2.38,2.6-2.81,2.6-3.68,1.95s-.22-3.68-.22-3.68c0,0,.43-1.95.87-2.6s.22-1.3.22-1.3c0,0-.22-.43-1.73.22s-3.03,1.51-3.03,1.51c0,0-.87.43-1.3-.22s.65-3.46.65-3.46c0,0,2.38-6.92,9.52-9.52,7.14-2.6,9.09-.43,9.09-.43,0,0,.65.43,1.3.22s.43-.43.22-.87-.22-1.3.22-1.51,2.81-.22,2.81-.22c0,0,8.65.87,14.28-1.95,5.63-2.81,16.01-7.36,16.01-7.36,0,0,12.33-5.84,24.88-.22,0,0,6.27,3.46,7.57,4.33,0,0,1.3,1.3,2.81.65,1.51-.65,2.6-.65,2.6-.65,0,0,1.3,0,2.16.22s3.03.87,4.54.22,6.27-2.38,6.92-6.92,1.73-6.92-7.57-13.85c0,0-6.27-4.33-6.27-10.82s2.81-8.44,2.81-8.44c0,0,1.08-.87,2.16-.87Z" />
            </svg>
          ) : (
            <Icon name={icon} />
          )}
        </a>
      ))}
    </>
  )
}

<style>
  /* Match Starlight's touch target; color comes from .social-icons a (orchard.css). */
  a {
    padding: 0.5em;
    margin: -0.5em;
  }
</style>
